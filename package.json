{
  "name": "trust-gate",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:migrate": "bun run --cwd apps/backend db:migrate",
    "db:generate": "bun run --cwd apps/backend db:generate",
    "benchmark": "bun run --cwd packages/benchmark start"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@types/bun": "^1.3.14",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
