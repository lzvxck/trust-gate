DATABASE_URL=postgres://trustgate:trustgate@localhost:5432/trustgate
REDIS_URL=redis://localhost:6379
PORT=3001
HOST=0.0.0.0
RUNS_API_TOKEN=dev-local-token

# GitHub App creds -- see https://github.com/settings/apps/<your-app>
GITHUB_APP_ID=123456
GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_APP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app-private-key.pem

# LLM judge (optional, advisory-only -- see plan §6). BYO key; omit both to disable.
# Groq's OpenAI-compatible API (https://api.groq.com/openai/v1). GROQ_MODEL is only
# required if GROQ_API_KEY is set. openai/gpt-oss-120b is a good free-tier default --
# supports Groq's structured_outputs and is cheap ($0.15/$0.60 per M tokens).
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
