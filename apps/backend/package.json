{
  "name": "@trust-gate/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "bun src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test --pass-with-no-tests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "judge:calibrate": "bun src/judge/calibrate.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.7.10",
    "@bull-board/fastify": "^6.7.10",
    "@fastify/env": "^5.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@trust-gate/orchestrator": "workspace:*",
    "bullmq": "^5.34.10",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "ioredis": "5.10.1",
    "openai": "^6.45.0",
    "postgres": "^3.4.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.2",
    "typescript": "^5.7.3"
  }
}
