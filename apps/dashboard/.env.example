DATABASE_URL=postgres://trustgate:trustgate@localhost:5432/trustgate
BETTER_AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BETTER_AUTH_URL=http://localhost:3000

# Same GitHub App as the backend -- GitHub Apps support the standard OAuth
# authorize/token flow, so no separate OAuth App is needed. Set a Callback URL
# on the App: http://localhost:3000/api/auth/callback/github
GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxxxxxx
GITHUB_APP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

BACKEND_URL=http://localhost:3001
# Must match the backend's RUNS_API_TOKEN -- server-to-server auth for the
# dashboard's calls into the backend REST API.
BACKEND_API_TOKEN=dev-local-token

# Comma-separated allowlist of emails permitted to sign in. There's no per-user
# data scoping (self-hosted instances are single-tenant -- everyone who's signed
# in sees the same shared data), so this is the actual access boundary. Unset
# means unrestricted sign-in -- fine for a quick local trial, not recommended
# for anything reachable beyond localhost.
ALLOWED_EMAILS=you@example.com,teammate@example.com
